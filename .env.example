# Copy to .env and add your token
# ipinfo.io - 50k lookups/month free
# https://ipinfo.io/account/token
IPINFO_TOKEN=your_token_here

# AbuseIPDB - 1000 checks/day free
# https://www.abuseipdb.com/account/api
ABUSEIPDB_TOKEN=your_token_here

# VirusTotal - 500 lookups/day free (4/min)
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_TOKEN=your_token_here

# GreyNoise Community API
# Free accounts no longer get an API key (the key page is sales-gated),
# so use keyless community mode - 10 IP lookups/day, no account needed:
GREYNOISE_COMMUNITY=true
# Only if your plan includes API access (a workspace ID is NOT a key):
GREYNOISE_TOKEN=
# Set GREYNOISE_COMMUNITY=false and leave the token empty to disable
# (then no alert IPs are ever sent to GreyNoise).
# https://docs.greynoise.io/docs/using-the-greynoise-community-api